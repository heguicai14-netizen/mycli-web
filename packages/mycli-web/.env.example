# Live LLM integration test credentials.
#
# Copy this file to `.env` (which is git-ignored) and fill in your API key.
# `bun run test:live` then runs the integration suite against the configured
# OpenAI-compatible endpoint.
#
# Defaults below target Zhipu BigModel's GLM-4.6 — swap for OpenAI / OpenRouter
# / a self-hosted vLLM by changing all three vars.

# Required. Without this, integration tests are silently skipped.
MYCLI_TEST_API_KEY=sk-your-bigmodel-key

# OpenAI-compatible base URL. Trailing slash is fine, /chat/completions is
# appended automatically.
MYCLI_TEST_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# Model id passed to the chat/completions endpoint.
MYCLI_TEST_MODEL=glm-4-flash
